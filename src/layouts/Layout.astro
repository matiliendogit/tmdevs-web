---
import '../styles/global.css';
import logoXs from '../assets/TM-devs-logo-xs.png';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title = 'TMdevs — Software a Medida para Negocios Reales',
  description = 'Desarrollamos sitios web, aplicaciones PWA y software especializado. Expertos en software para laboratorios. Córdoba y La Pampa, Argentina.',
  ogImage = 'https://tmdevs.com/og-image.jpg',
} = Astro.props;

const canonicalURL = Astro.props.canonicalURL ?? Astro.url.href;

// json for structured data (schema.org) - https://developers.google.com/search/docs/appearance/structured-data/intro-structured-data
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': ['Organization', 'LocalBusiness'],
  name: 'TMdevs',
  url: 'https://tmdevs.com',
  logo: 'https://tmdevs.com/favicon.png',
  description: 'Desarrollo de software a medida: sitios web modernos, aplicaciones PWA y software especializado para laboratorios. Córdoba y La Pampa, Argentina.',
  email: 'hola@tmdevs.com',
  sameAs: [],
  address: [
    {
      '@type': 'PostalAddress',
      addressLocality: 'Córdoba',
      addressRegion: 'Córdoba',
      addressCountry: 'AR',
    },
    {
      '@type': 'PostalAddress',
      addressLocality: 'Santa Rosa',
      addressRegion: 'La Pampa',
      addressCountry: 'AR',
    },
  ],
  areaServed: {
    '@type': 'Country',
    name: 'Argentina',
  },
  knowsAbout: [
    'Desarrollo Web',
    'Aplicaciones PWA',
    'Software para Laboratorios',
    'Automatización de Procesos',
    'Software de Gestión',
    'Node.js',
    'React',
  ],
  offers: {
    '@type': 'Offer',
    itemOffered: [
      { '@type': 'Service', name: 'Sitios Web Modernos' },
      { '@type': 'Service', name: 'Web Apps & PWA' },
      { '@type': 'Service', name: 'Software para Laboratorios' },
    ],
  },
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <meta name="theme-color" content="#1a1a18" />

    <!-- Canonical + hreflang -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="TMdevs — Desarrollo de Software a Medida" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="TMdevs" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="TMdevs — Desarrollo de Software a Medida" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href={logoXs.src} />
    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={jsonLd} />
  </head>
  <body>
    <div class="cursor" id="cursor" aria-hidden="true"></div>
    <slot/>

    <!-- Mouse vs keyboard cursor detection -->
    <script>
      const html = document.documentElement;
      document.addEventListener('mousemove', () => html.classList.add('using-mouse'));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Tab') html.classList.remove('using-mouse');
      });
    </script>
  </body>
</html>
